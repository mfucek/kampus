// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Clerk account

model Account {
  id String @id @default(cuid())

  clerkUserId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stripeCustomerId String?

  package     PackageType?
  status      AccountStatus @default(INACTIVE)
  activeUntil DateTime?

  user                User?
  permissionOverrides Permissions?
}

enum PackageType {
  MONTHLY_CHEAP
  MONTHLY_PRO
  LIFETIME
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  CANCELLED
}

// User

model User {
  id String @id @default(cuid())

  displayName String
  imageUrl    String?

  badge String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id])

  votes Vote[]
  posts Post[]

  image ImageFile?

  notifications Notification[]
  // subscriptions Subscription[]
}

// College

model College {
  id String @id @default(cuid())

  slug String @unique
  name String

  iconSrc String?

  topics Topic[]
  posts  Post[]

  image ImageFile?
}

// Subjects & Staff

model Topic {
  id String @id @default(cuid())

  slug String
  name String

  collegeId String
  college   College @relation(fields: [collegeId], references: [id])

  type TopicType

  subject Subject?
  staff   Staff?
  posts   Post[]

  image     ImageFile?
  summaries Summary[]
  // notifications Notification[]
  // Subscription Subscription[]

  @@unique([collegeId, slug])
}

enum TopicType {
  SUBJECT
  STAFF
}

model Staff {
  topicId String @id @unique
  topic   Topic  @relation(fields: [topicId], references: [id])

  imageUrl String?

  subjects Subject[]
}

model Subject {
  topicId String @id @unique
  topic   Topic  @relation(fields: [topicId], references: [id])

  semester    Int?
  ects        Int?
  subjectCode String?
  subjectLink String?

  tags String[]

  staffs Staff[]
}

// Posts

model Post {
  id String @id @default(cuid())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  // college this post belongs to
  collegeId String
  college   College @relation(fields: [collegeId], references: [id])

  // subject or staff this post belongs to
  // if empty, this is college-specific post
  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id])

  // direct replies
  // if empty, this is top level post
  replyToId String?
  replyTo   Post?   @relation(fields: [replyToId], references: [id], name: "PostReplies")
  replies   Post[]  @relation("PostReplies")

  // content
  body Json?

  votes Vote[]

  files File[]
  // notifications Notification[]
  // subscriptions Subscription[]
}

enum VoteType {
  UP
  DOWN
}

model Vote {
  id String @id @default(cuid())

  type VoteType

  postId String
  post   Post   @relation(fields: [postId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

// Files

model File {
  id String @id @default(cuid())

  key  String   @unique
  type FileType

  authorId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documentFile DocumentFile?
  imageFile    ImageFile?

  postId String?
  post   Post?   @relation(fields: [postId], references: [id])
}

model ImageFile {
  fileId String @id @unique
  file   File   @relation(fields: [fileId], references: [id])

  topicId String? @unique
  topic   Topic?  @relation(fields: [topicId], references: [id])

  collegeId String?  @unique
  college   College? @relation(fields: [collegeId], references: [id])

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])
}

model DocumentFile {
  fileId String @id @unique
  file   File   @relation(fields: [fileId], references: [id])

  title String?

  academicYear String?

  types DocumentFileType[]
}

enum DocumentFileType {
  EXAM
  COLOQUIUM
  COLOQUIUM_MID
  COLOQUIUM_FINAL
  EXERCISE
  HOMEWORK
  SEMINAR
  SCRIPT
  PAPER
  OTHER
  SUMMER_EXAM
  FALL_EXAM
  WINTER_EXAM
  SPRING_EXAM
  CORRECTION_EXAM
  ORAL_EXAM
  SOLVED
}

enum FileType {
  IMAGE
  PDF
  ARCHIVE
}

// permissions

model Permissions {
  accountId String  @id
  account   Account @relation(fields: [accountId], references: [id])

  // base role
  baseRole RoleType @default(BASE)

  // overrides
  canEnterPlatform Boolean?

  canPost  Boolean?
  canReply Boolean?
  canVote  Boolean?

  canUploadFiles  Boolean?
  canUploadImages Boolean?

  canChangeTheme      Boolean?
  canViewAllSummaries Boolean?

  canSuggestTopics  Boolean?
  canApproveTopics  Boolean?
  canManageTopics   Boolean?
  canManageColleges Boolean?

  canDeleteOthersPosts Boolean?

  canDeleteUsers       Boolean?
  canManageUserRoles   Boolean?
  canManagePermissions Boolean?
}

enum RoleType {
  BASE
  MODERATOR
  ADMIN
}

// Summaries

model Summary {
  id String @id @default(cuid())

  title     String
  content   String
  sentiment SummaryType

  topic   Topic  @relation(fields: [topicId], references: [id])
  topicId String
}

enum SummaryType {
  POSITIVE
  NEGATIVE
  NEUTRAL
  WARNING
}

