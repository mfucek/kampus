// ------------------
// Notifications
// ------------------

model Notification {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  type      NotificationType
  read      Boolean          @default(false)
  postId    String?
  authorId  String?
  // topicId String?

  recepientId String
  Recepient   User   @relation(fields: [recepientId], references: [id])
}

enum NotificationType {
  POST_REPLY
  POST_VOTE
  // TOPIC_NEW_POST
  // NEW_FEATURE
  PACKAGE_UPGRADE
  PACKAGE_DOWNGRADE
}
