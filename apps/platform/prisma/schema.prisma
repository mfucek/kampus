// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Clerk account

model Account {
  id String @id @default(cuid())

  clerkUserId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stripeCustomerId String?

  package     PackageType?
  status      AccountStatus @default(INACTIVE)
  activeUntil DateTime?

  user User?
}

enum PackageType {
  MONTHLY_CHEAP
  MONTHLY_PRO
  LIFETIME
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  CANCELLED
}

// User

model User {
  id String @id @default(cuid())

  displayName String
  imageUrl    String?

  badge String? // Make sure this line is present

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id])

  Vote Vote[]
  Post Post[]

  ProfileIcon ProfileIcon[]
}

// College

model College {
  id String @id @default(cuid())

  slug String @unique
  name String

  iconSrc String?

  Topic Topic[]
  Post  Post[]

  CollegePicture CollegeIcon[]
}

// Subjects & Staff

model Topic {
  id String @id @default(cuid())

  slug String
  name String

  collegeId String
  college   College @relation(fields: [collegeId], references: [id])

  type TopicType

  subject   Subject?
  staff     Staff?
  Post      Post[]
  TopicIcon TopicIcon[]

  @@unique([collegeId, slug])
}

enum TopicType {
  SUBJECT
  STAFF
}

model Staff {
  topicId String @id @unique
  topic   Topic  @relation(fields: [topicId], references: [id])

  imageUrl String?

  subjects Subject[]
}

model Subject {
  topicId String @id @unique
  topic   Topic  @relation(fields: [topicId], references: [id])

  semester Int?
  ects     Int?

  Staff Staff[]
}

// Posts

model Post {
  id String @id @default(cuid())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  // college this post belongs to
  collegeId String
  college   College @relation(fields: [collegeId], references: [id])

  // subject or staff this post belongs to
  // if empty, this is college-specific post
  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id])

  // direct replies
  // if empty, this is top level post
  replyToId String?
  replyTo   Post?   @relation(fields: [replyToId], references: [id], name: "PostReplies")
  replies   Post[]  @relation("PostReplies")

  // content
  body Json?

  votes Vote[]

  FilePost FilePost[]
}

enum VoteType {
  UP
  DOWN
}

model Vote {
  id String @id @default(cuid())

  type VoteType

  postId String
  post   Post   @relation(fields: [postId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

// Files

model File {
  id String @id @default(cuid())

  key  String   @unique
  type FileType

  authorId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  FilePost    FilePost[]
  ProfileIcon ProfileIcon[]
  CollegeIcon CollegeIcon[]
  TopicIcon   TopicIcon[]
}

model FilePost {
  fileId String @id @unique
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  postId String
  post   Post   @relation(fields: [postId], references: [id])

  tags String[]
}

model ProfileIcon {
  fileId String @unique
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  userId String @id @unique
  user   User   @relation(fields: [userId], references: [id])
}

model CollegeIcon {
  fileId String @id @unique
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  collegeId String
  college   College @relation(fields: [collegeId], references: [id])
}

model TopicIcon {
  fileId String @id @unique
  file   File   @relation(fields: [fileId], references: [id])

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id])
}

enum FileType {
  IMAGE
  PDF
}

enum SentimentType {
  POSITIVE
  NEGATIVE
  NEUTRAL
  WARNING
}

